// BicycleExchange Database Schema
// Paste this into https://dbdiagram.io/

Table users {
  user_id integer [primary key]
  username varchar
  password varchar
  full_name varchar
  phone varchar
  email varchar
  role varchar
  status varchar
  address varchar
  avatar varchar
  google_id varchar
  created_at date
  create_date date
}

Table brand {
  brand_id integer [primary key]
  name varchar
}

Table category {
  category_id integer [primary key]
  name varchar
  bicycle_type varchar
}

Table bicycle {
  bike_id integer [primary key]
  bike_type varchar
  brake_type varchar
  color varchar
  drivetrain varchar
  fork_type varchar
  frame_material varchar
  frame_size varchar
  number_of_gears varchar [not null]
  wheel_size varchar
  year_manufacture integer [not null]
  chain varchar
  chainring varchar
  fork varchar
  handlebar varchar
  rim varchar
  saddle varchar
  shock_absorber varchar
  weight double
  bike_condition integer
  brand_id integer [ref: > brand.brand_id]
  category_id integer [ref: > category.category_id]
}

Table bicycle_library {
  id integer [primary key]
  bike_type varchar
  brake_type varchar
  chain varchar
  chainring varchar
  color varchar
  drivetrain varchar
  fork_type varchar
  frame_material varchar
  frame_size varchar
  handlebar varchar
  model varchar
  number_of_gears varchar
  rim varchar
  saddle varchar
  shock_absorber varchar
  weight double
  wheel_size varchar
  year_manufacture integer [not null]
  brand_id integer [ref: > brand.brand_id]
  category_id integer [ref: > category.category_id]
}

Table bike_listing {
  listing_id integer [primary key]
  title varchar
  description varchar
  image_url varchar
  price double [not null]
  condition varchar
  status varchar
  created_at timestamp
  updated_at timestamp
  bicycle_id integer [unique, ref: - bicycle.bike_id]
  seller_id integer [ref: > users.user_id]
}

Table events {
  event_id integer [primary key]
  name varchar
  type varchar
  bike_type varchar
  location varchar
  address varchar
  latitude double
  longitude double
  status varchar
  create_date date
  public_date date
  start_date date
  end_date date
  update_date date
  create_by integer [ref: > users.user_id]
}

Table event_bicycle {
  event_bike_id integer [primary key]
  title varchar
  bike_type varchar
  type varchar
  seller_name varchar
  price double
  condition varchar
  image_url varchar
  status varchar
  create_date date
  update_date date
  event_id integer [ref: > events.event_id]
  listing_id integer [ref: > bike_listing.listing_id]
  bike_id integer [ref: > bicycle.bike_id]
  user_id integer [ref: > users.user_id]
}

Table event_inspector {
  inspec_id integer [primary key]
  status varchar
  create_date timestamp
  event_id integer [ref: > events.event_id]
  user_id integer [ref: > users.user_id]
}

Table deposit {
  deposit_id integer [primary key]
  amount double [not null]
  type varchar
  status varchar
  created_at timestamp
  listing_id integer [ref: > bike_listing.listing_id]
  event_bike_id integer [ref: > event_bicycle.event_bike_id]
  user_id integer [ref: > users.user_id]
}

Table reservation {
  reservation_id integer [primary key]
  status varchar
  deposit_amount double
  meeting_location varchar
  meeting_time timestamp
  latitude double
  longitude double
  cancel_description varchar
  cancel_image varchar
  reserved_at timestamp
  buyer_id integer [ref: > users.user_id]
  inspector_id integer [ref: > users.user_id]
  listing_id integer [ref: > bike_listing.listing_id]
  event_bike_id integer [ref: > event_bicycle.event_bike_id]
  deposit_id integer [unique, ref: - deposit.deposit_id]
}

Table check_in {
  check_in_id integer [primary key]
  buyer_name varchar
  buyer_phone varchar
  seller_name varchar
  seller_phone varchar
  token varchar
  status varchar
  buyer_id integer [ref: > users.user_id]
  seller_id integer [ref: > users.user_id]
  reservation_id integer [ref: > reservation.reservation_id]
  event_bike_id integer [ref: > event_bicycle.event_bike_id]
  listing_id integer [ref: > bike_listing.listing_id]
}

Table transaction {
  transaction_id integer [primary key]
  actual_price double [not null]
  amount double [not null]
  fee double [not null]
  type varchar
  status varchar
  description varchar
  create_at timestamp
  update_at timestamp
  buyer_id integer [ref: > users.user_id]
  seller_id integer [ref: > users.user_id]
  listing_id integer [ref: > bike_listing.listing_id]
  event_id integer [ref: > events.event_id]
  event_bike_id integer [ref: > event_bicycle.event_bike_id]
  deposit_id integer [unique, ref: - deposit.deposit_id]
  reservation_id integer [unique, ref: - reservation.reservation_id]
}

Table dispute {
  dispute_id integer [primary key]
  reason varchar
  reason_category varchar
  status varchar
  created_at timestamp
  raised_by integer [ref: > users.user_id]
  assigned_inspector_id integer [ref: > users.user_id]
  transaction_id integer [unique, ref: - transaction.transaction_id]
}

Table inspection_report {
  report_id integer [primary key]
  result varchar
  checklist_items text
  note varchar
  reason varchar
  created_at timestamp
  inspector_id integer [ref: > users.user_id]
  reservation_id integer [ref: > reservation.reservation_id]
  dispute_id integer [unique, ref: - dispute.dispute_id]
}

Table wallet {
  wallet_id integer [primary key]
  balance double [not null]
  username varchar
  type varchar
  updated_at timestamp
  user_id integer [unique, ref: - users.user_id]
}

Table wallet_transaction {
  wallet_trans_id integer [primary key]
  amount double [not null]
  type varchar
  description varchar
  balance double
  create_at timestamp
  wallet_id integer [ref: > wallet.wallet_id]
}

Table wishlist {
  wishlist_id integer [primary key]
  listing_id integer [ref: > bike_listing.listing_id]
  user_id integer [ref: > users.user_id]
}

Table system_config {
  config_id integer [primary key]
  key varchar
  value double [not null]
  description varchar
}

Table invalidate_token {
  id varchar [primary key]
  expiry_date timestamp
}
